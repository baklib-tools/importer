{
  "site_id": 1,
  "api": {
    "base_url": "https://open.baklib.com/api/v1",
    "access_key": "your_access_key_here",
    "secret_key": "your_secret_key_here"
  },
  "import": {
    "max_depth": 9,
    "delay": 0.5,
    "retry": 3,
    "start_row": 2,
    "path_prefix": "FileServer/Share",
    "_comment": "路径前缀：支持带或不带开头 '/'，如 'data/share' 或 '/data/share'，代码会规范化处理",
    "skip_directories": [],
    "_comment_skip_directories": "可选：跳过以下相对路径（相对 path_prefix）及其子目录，不导入。示例：[\"temp/ignore\", \"test\"]",
    "columns": {
      "path": "E",
      "tags": "A",
      "new_dir": "B"
    }
  },
  "logging": {
    "log_file": "import_log.log",
    "level": "INFO"
  }
}
